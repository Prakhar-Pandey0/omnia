# Orchestrator Inventory
# Generated by orchestrator.yml
# Contains functional groups and their member nodes with admin IPs
---
all:
  children:
{% for group_name in nodes | map(attribute='value.FUNCTIONAL_GROUP_NAME') | unique | sort %}
    {{ group_name }}:
      hosts:
{% for item in nodes | sort(attribute='value.XNAME') %}
{% if item.value.FUNCTIONAL_GROUP_NAME == group_name %}
        {{ item.value.HOSTNAME }}:
          admin_ip: {{ item.value.ADMIN_IP }}
          bmc_ip: {{ item.value.BMC_IP }}
          service_tag: {{ item.value.SERVICE_TAG }}
          group_name: {{ item.value.GROUP_NAME }}
{% endif %}
{% endfor %}
{% endfor %}
